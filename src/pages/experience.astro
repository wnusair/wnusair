---
import BasicLayout from "../layouts/BasicLayout.astro";
import { SITE } from "../site-config";
import { Icon } from "astro-icon/components";

const experiences = [
  {
    role: "Internship",
    company: "5/3rd Bank Corporation",
    location: "Cincinnati, Ohio, United States",
    date: "June 2026 - August 2026",
    points: [
      "Engineered RAG Architecture allowing employees to talk to hundreds of files stored in S3 Buckets",
      "Deployed LLM Evaluation Software into Autonomous call-center agent",
      "Developed tool allowing developers to prompt Confluence pages (documentation) via RAG in ECS instance"
    ]
  },
  {
    role: "Internship",
    company: "Procter and Gamble",
    location: "Cincinnati, Ohio, United States",
    date: "June 2025 - August 2025",
    points: [
      "Automated data cleaning, transfer, and visualization process with SAP and ABAP, partnered with MIT Undergraduate",
      "— Saved $144,000 and 4,800 labor hours",
      "Developed internal library to offload heavy computations to supercomputers in Python CloudPickle"
    ]
  },
  {
    role: "Research",
    company: "Miami University",
    location: "Hamilton, Ohio, United States",
    date: "September 2025 - Present",
    points: [
      "Developed ML models to correct depth calculations in LiDAR by ~18% using Tensorflow and Pytorch",
      "Beat $250,000 contractor to develop a telemetry hub for advanced manufacturing machinery",
      "Early-stage SAAS development of central HUB for manufacturing machinery"
    ]
  },
  {
    role: "Chief Information Officer",
    company: "INTERalliance Leadership Council",
    location: "",
    date: "Grade 11 - 12",
    points: [
      "Lead Web developer; develop the INTERalliance and TechOlympics website, thousands of weekly visitors",
      "Manage the IT infrastructure of TechOlympics, the nation's largest student IT conference",
      "Partnered with 20+ Board members from top Ohio universities and Fortune 500 companies"
    ]
  },
  {
    role: "Co-President",
    company: "Hack Club",
    location: "",
    date: "Grade 9 - 12",
    points: [
      "Grew the club by 6x, personally tutored 30 students in intermediate Python and SQL",
      "Raising $2,500+ for the annual hackathon with 83 competitors"
    ]
  }
];
---

<BasicLayout
  title={`Experience - ${SITE.author.fullName}`}
  description="My professional experience and timeline."
>
  <main class="w-screen min-h-screen flex flex-col justify-center items-center text-white p-4">
    <div class="max-w-3xl w-full p-8 bg-darkslate-700 border border-darkslate-400 rounded-lg shadow-lg relative my-8">
      <div class="flex flex-col sm:flex-row justify-between items-center mb-8 mt-6 gap-4">
        <a href="/" class="text-primary-500 hover:text-white transition-colors flex items-center gap-1 self-start sm:self-auto">
          <Icon name="ri:arrow-left-line" class="text-lg" /> Back
        </a>
        <a href="/resume.pdf" aria-label="download resume" target="_blank" download class="px-4 py-2 border border-primary-500 rounded-md text-primary-500 hover:bg-primary-500 hover:text-white transition-colors text-sm font-semibold flex items-center gap-2 self-start sm:self-auto">
          <Icon name="ri:file-download-line" class="text-lg" />
          Download Resume
        </a>
      </div>
      <h1 class="text-3xl font-bold mb-8 text-center text-primary-500">Professional Experience</h1>
      
      <div class="relative border-l border-darkslate-400 ml-4 sm:ml-6 flex-1 flex flex-col gap-10 pl-6 sm:pl-8 py-4">
        {experiences.map((exp, index) => (
          <div class="relative">
            <div class={`absolute -left-[33px] sm:-left-[41px] top-1.5 h-4 w-4 rounded-full border-2 border-darkslate-900 ${index === 0 ? 'bg-primary-500' : 'bg-darkslate-300'}`}></div>
            <h3 class="text-xl font-bold text-white">{exp.company}</h3>
            <p class="text-sm text-primary-400 font-semibold">{exp.role} <span class="text-darkslate-300 font-normal">&bull; {exp.date}</span></p>
            {exp.location && <p class="text-xs text-darkslate-300 mt-0.5">{exp.location}</p>}
            <ul class="mt-3 text-gray-300 font-light list-disc ml-4 space-y-1">
              {exp.points.map(point => (
                <li class="text-sm">{point}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      
      <div class="mt-10 flex justify-center">
        <a href="/resume.pdf" aria-label="download resume" target="_blank" download class="px-6 py-3 border border-primary-500 rounded-md text-primary-500 hover:bg-primary-500 hover:text-white transition-colors font-semibold flex items-center justify-center gap-2">
          <Icon name="ri:file-download-line" class="text-lg" />
          Download Wissam's Resume
        </a>
      </div>
    </div>
  </main>
</BasicLayout>
